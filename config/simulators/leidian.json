{
    "name": "雷电模拟器",
    "type": "leidian",
    "window_class": "LDPlayerMainFrame",
    "window_title": "雷电模拟器",
    "control_method": "adb",
    "adb": {
        "path": "C:/LDPlayer/LDPlayer4.0/adb.exe",
        "port": 5555,
        "connect_timeout": 10,
        "reconnect_on_failure": true,
        "base_resolution": {
            "width": 1280,
            "height": 720
        }
    },
    "screen": {
        "width": 1280,
        "height": 720,
        "dpi": 240,
        "recommended_for_ocr": true
    },
    "performance": {
        "click_delay": 0.5,
        "screenshot_delay": 0.3,
        "template_scale": 1.0
    },
    "custom_commands": {
        "start_simulator": "C:/LDPlayer/LDPlayer4.0/LDPlayer.exe",
        "stop_simulator": "taskkill /f /im LdBoxHeadless.exe"
    }
}
