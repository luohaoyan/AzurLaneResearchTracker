    "performance": {
        "click_delay": 0.5,
        "screenshot_delay": 0.3,
        "template_scale": 1.0
    },
    "custom_commands": {
        "start_simulator": "D:/MuMuPlayer-12.0/MuMuPlayer.exe",
        "stop_simulator": "taskkill /f /im MuMuPlayer.exe"
    }
}
